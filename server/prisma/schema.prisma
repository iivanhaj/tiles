generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  tiles        Tile[]
}

model Tile {
  id          String   @id @default(cuid())
  userId      String
  dateString  String
  imageUrl    String
  caption     String?
  moodType    String
  sourceType  String
  capturedAt  DateTime
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id])

  @@unique([userId, dateString])
}